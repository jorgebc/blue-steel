<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!--
    Local profile: human-readable console output for developer ergonomics.
    All other profiles: structured JSON via LogstashEncoder for log aggregation (D-072).

    LLM call logging must emit: session_id, user_id, stage, tokens_in, tokens_out, cost_usd
    as structured MDC fields on every LLM log line (LOG-01, D-072).
  -->

  <springProfile name="local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <!-- Project packages at DEBUG in local; third-party noise suppressed at WARN -->
    <logger name="com.bluesteel" level="DEBUG"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="liquibase" level="WARN"/>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <springProfile name="!local">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <!-- Third-party noise suppressed at WARN in production; DEBUG disabled by root INFO -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="liquibase" level="WARN"/>

    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>
  </springProfile>

</configuration>
