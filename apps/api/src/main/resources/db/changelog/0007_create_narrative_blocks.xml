<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="0007-create-narrative-blocks" author="jorge">

    <createTable tableName="narrative_blocks">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="session_id" type="UUID">
        <constraints nullable="false"
                     foreignKeyName="fk_narrative_blocks_session"
                     references="sessions(id)"/>
      </column>
      <column name="raw_summary_text" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="token_count" type="INTEGER">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <rollback>
      <dropTable tableName="narrative_blocks"/>
    </rollback>

  </changeSet>

</databaseChangeLog>
