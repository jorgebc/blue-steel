<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!--
    Complete the campaign-delete cascade chain. Migrations 0020–0021 added
    CASCADE to the direct campaign_id FKs and to narrative_blocks→sessions.
    The remaining tables also need CASCADE on their session or parent-entity
    FKs so that deleting a campaign (which cascades to sessions, actors,
    spaces, events, relations, and proposals) does not leave orphaned rows.

    Tables referencing sessions (created_in_session / session_id FKs):
      actors, actor_versions, spaces, space_versions,
      events, event_versions, relations, relation_versions, entity_embeddings

    Tables referencing their parent world-state entity:
      actor_versions→actors, space_versions→spaces,
      event_versions→events, relation_versions→relations

    Table referencing proposals:
      proposal_votes→proposals
  -->

  <!-- actors.created_in_session_id → sessions -->
  <changeSet id="0022-actors-cascade-session" author="jorge">
    <dropForeignKeyConstraint baseTableName="actors"
                              constraintName="fk_actors_created_in_session"/>
    <addForeignKeyConstraint baseTableName="actors"
                             baseColumnNames="created_in_session_id"
                             referencedTableName="sessions"
                             referencedColumnNames="id"
                             constraintName="fk_actors_created_in_session"
                             onDelete="CASCADE"/>
  </changeSet>

  <!-- actor_versions.session_id → sessions -->
  <changeSet id="0022-actor-versions-cascade-session" author="jorge">
