<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!-- Relation version table — append-only history (D-035, D-001, D-003) -->
  <changeSet id="0015-create-relation-versions" author="jorge">

    <createTable tableName="relation_versions">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="relation_id" type="UUID">
        <constraints nullable="false"
                     foreignKeyName="fk_relation_versions_relation"
                     references="relations(id)"/>
      </column>
      <column name="session_id" type="UUID">
        <constraints nullable="false"
                     foreignKeyName="fk_relation_versions_session"
                     references="sessions(id)"/>
      </column>
      <column name="version_number" type="INTEGER">
        <constraints nullable="false"/>
      </column>
      <column name="changed_fields" type="JSONB">
        <constraints nullable="true"/>
      </column>
      <column name="full_snapshot" type="JSONB">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <sql>
      CREATE INDEX idx_relation_versions_relation_id ON relation_versions (relation_id);
    </sql>

    <rollback>
      <dropIndex tableName="relation_versions" indexName="idx_relation_versions_relation_id"/>
      <dropTable tableName="relation_versions"/>
    </rollback>

  </changeSet>

</databaseChangeLog>
