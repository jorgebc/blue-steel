    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
