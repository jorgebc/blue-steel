#!/usr/bin/env bash
# Git pre-push hook — runs CI-equivalent checks before any push.
# Installed via: git config core.hooksPath .githooks
#
# Skip with: SKIP_CI_CHECKS=1 git push  (use only when checks already verified)

set -euo pipefail

if [ "${SKIP_CI_CHECKS:-0}" = "1" ]; then
  echo "[pre-push] SKIP_CI_CHECKS=1 — skipping checks."
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "[pre-push] Running PR checks before push..."
exec "$REPO_ROOT/scripts/check-pr.sh"
