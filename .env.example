# Copy this file to .env.local for local development.
# Never commit .env or .env.local — both are gitignored (D-092).
# Production values are stored in the Render dashboard (Service → Environment) and in Vercel dashboard.

# ─── Backend / Shared ────────────────────────────────────────────────────────

# Neon PostgreSQL connection string (local: use docker-compose credentials)
DATABASE_URL=

# Google AI Studio (Gemini) — chat + embeddings under one key (only with the llm-real
# Spring profile). Get a key at https://aistudio.google.com/api-keys (D-093).
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=           # default gemini-2.5-flash — env-overridable, no DB impact
GEMINI_EMBEDDING_MODEL=      # default gemini-embedding-001 (3072 dims)

# Local LLM via Ollama — only with the llm-ollama profile; offline, no API keys (D-088).
# Run Ollama, then: `ollama pull bge-m3` and `ollama pull qwen2.5:7b`.
OLLAMA_BASE_URL=             # default http://localhost:11434
OLLAMA_CHAT_MODEL=           # default qwen2.5:7b — freely swappable, no DB impact
OLLAMA_EMBEDDING_MODEL=      # default bge-m3 (1024 dims)
# pgvector embedding column dimension (default 3072 for gemini-embedding-001 under llm-real;
# set 1024 for bge-m3 under llm-ollama). Changing it to match a different embedding model
# requires recreating the DB (docker compose down -v) — a pgvector column's dimension is
# fixed at create time.
EMBEDDING_DIMENSION=

# JWT HS256 symmetric secret — minimum 32 random bytes, base64 or hex encoded
JWT_SECRET=

# Transactional email provider API key (Resend recommended — D-075)
EMAIL_API_KEY=

# Admin bootstrap: seeded on first startup via ApplicationReadyEvent (D-073)
# The admin account is a singleton — exactly one per platform instance (D-025)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS allowed origin — the frontend URL the backend permits cross-origin requests from.
# Local dev: not needed (application-local.properties hardcodes http://localhost:5173).
# Production: set in Render dashboard to your Vercel URL (e.g. https://bluesteel.vercel.app)
# Spring property: cors.allowed-origins
CORS_ALLOWED_ORIGIN=

# Session ingestion: maximum token budget per summary (estimated via char/4 heuristic)
# Spring property: blue-steel.ingestion.max-tokens
BLUE_STEEL_INGESTION_MAX_TOKENS=

# Session ingestion: maximum minutes a session may remain in "processing"
# before stuck-recovery transitions it to "failed" (D-074)
# Spring property: blue-steel.ingestion.processing-timeout-minutes
BLUE_STEEL_INGESTION_PROCESSING_TIMEOUT_MINUTES=

# Session ingestion: how often (ms) the scheduled TTL recovery checker runs (D-074)
# Spring property: blue-steel.ingestion.processing-timeout-check-interval-ms
BLUE_STEEL_INGESTION_PROCESSING_TIMEOUT_CHECK_INTERVAL_MS=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────

# Backend base URL — used by the frontend API client
# Local dev: http://localhost:8080
# Production: set in Vercel dashboard to your Render service URL (e.g. https://blue-steel-api.onrender.com)
VITE_API_BASE_URL=

# ─── AI Pipeline ────────────────────────────────────────────────────────────

# LLM token budget per extraction call — estimated via char/4 heuristic (D-034)
# Spring property: blue-steel.llm.extraction-max-tokens
BLUE_STEEL_LLM_EXTRACTION_MAX_TOKENS=

# LLM token budget per entity resolution call (D-034, D-041)
# Spring property: blue-steel.llm.resolution-max-tokens
BLUE_STEEL_LLM_RESOLUTION_MAX_TOKENS=

# Entity resolution similarity floor — mentions below this cosine score are classified NEW (D-041)
# Spring property: blue-steel.resolution.similarity-floor
BLUE_STEEL_RESOLUTION_SIMILARITY_FLOOR=

# Entity resolution top-N candidates forwarded to LLM Stage 2 (D-041)
# Spring property: blue-steel.resolution.top-n
BLUE_STEEL_RESOLUTION_TOP_N=

# SonarQube user token for the local sonarqube-local Podman container.
# Generate: SonarQube UI → My Account → Security → Generate Token.
# Required by .ai/pipeline (BE engineer Sonar gate). D-050: never commit.
SONAR_TOKEN=
